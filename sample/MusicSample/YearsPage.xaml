<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MusicSample.YearsPage"
             Title="Years">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <Button x:Name="BtnLoad"
                Text="Load Years"
                Clicked="OnLoadYears" />

        <CollectionView Grid.Row="1"
                        x:Name="YearList"
                        SelectionMode="Single"
                        SelectionChanged="OnYearSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="8,12">
                        <Label Text="{Binding Value}"
                               FontSize="16" />
                        <Label Grid.Column="1"
                               Text="{Binding Count, StringFormat='{0} tracks'}"
                               FontSize="14"
                               TextColor="Gray" />
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="20"
                               TextColor="Gray"
                               VerticalOptions="Center"
                               Margin="8,0,0,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No years loaded. Grant permission on the Library tab, then tap 'Load Years'."
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="Gray"
                       Margin="20" />
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>

</ContentPage>
